<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_inventory_notification_thresholds" model="ir.cron">
            <field name="name">Check Inventory Stock Thresholds</field>
            <field name="model_id" ref="model_inventory_monitoring_notification"/>
            <field name="state">code</field>
            <field name="code">model.check_thresholds()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="user_id" ref="base.user_admin"/>
        </record>
    </data>
</odoo>
