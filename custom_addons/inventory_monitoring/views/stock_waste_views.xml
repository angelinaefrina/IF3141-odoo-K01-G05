<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_stock_waste_form" model="ir.ui.view">
            <field name="name">inventory.monitoring.stock.waste.form</field>
            <field name="model">inventory.monitoring.stock.waste</field>
            <field name="arch" type="xml">
                <form string="Stock Waste">
                    <sheet>
                        <group>
                            <field name="material_id"/>
                            
                            <label for="quantity"/>
                            <div class="o_row">
                                <field name="quantity"/>
                                <strong><field name="uom"/></strong>
                            </div>
                            
                            <field name="date"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_stock_waste_search" model="ir.ui.view">
            <field name="name">inventory.monitoring.stock.waste.search</field>
            <field name="model">inventory.monitoring.stock.waste</field>
            <field name="arch" type="xml">
                <search string="Cari Log Limbah">
                    <field name="material_id" string="Bahan Baku"/>
                    <field name="description" string="Deskripsi/Keterangan"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Bahan Baku" name="group_by_material" context="{'group_by':'material_id'}"/>
                        <filter string="Tanggal" name="group_by_date" context="{'group_by':'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_stock_waste_tree" model="ir.ui.view">
            <field name="name">inventory.monitoring.stock.waste.tree</field>
            <field name="model">inventory.monitoring.stock.waste</field>
            <field name="arch" type="xml">
                <tree string="Stock Waste">
                    <field name="date"/>
                    <field name="material_id"/>
                    <field name="quantity"/>
                    <field name="uom"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>
        
        <record id="action_stock_waste" model="ir.actions.act_window">
            <field name="name">Stock Waste Logs</field>
            <field name="res_model">inventory.monitoring.stock.waste</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_stock_waste_search"/>
        </record>
    </data>
</odoo>