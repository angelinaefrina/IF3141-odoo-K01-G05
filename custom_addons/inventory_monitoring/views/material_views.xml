<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Search View -->
        <record id="view_material_search" model="ir.ui.view">
            <field name="name">inventory.monitoring.material.search</field>
            <field name="model">inventory.monitoring.material</field>
            <field name="arch" type="xml">
                <search string="Search Materials">
                    <field name="name"/>
                    <group expand="0" string="Group By">
                        <filter string="Unit of Measure" name="group_by_uom" context="{'group_by':'uom'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View (Dashboard Style) -->
        <record id="view_material_kanban" model="ir.ui.view">
            <field name="name">inventory.monitoring.material.kanban</field>
            <field name="model">inventory.monitoring.material</field>
            <field name="arch" type="xml">
                <kanban class="o_kanban_mobile" sample="1">
                    <field name="name"/>
                    <field name="current_stock"/>
                    <field name="min_stock"/>
                    <field name="uom"/>
                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="o_kanban_record_top mb-2">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="font-size: 16px;"><field name="name"/></strong>
                                    </div>
                                    <div class="o_kanban_record_top_right">
                                        <span t-if="record.current_stock.raw_value &lt; record.min_stock.raw_value" class="badge rounded-pill" style="background-color: #dc3545; color: white; padding: 4px 8px;">Low Stock</span>
                                        <span t-if="record.current_stock.raw_value &gt;= record.min_stock.raw_value" class="badge rounded-pill" style="background-color: #198754; color: white; padding: 4px 8px;">In Stock</span>
                                    </div>
                                </div>
                                <hr style="margin: 6px 0;"/>
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left">
                                        <span class="text-muted">Min: <field name="min_stock"/> <field name="uom"/></span>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <strong t-attf-style="color: {{ record.current_stock.raw_value &lt; record.min_stock.raw_value ? '#dc3545' : '#198754' }}; font-size: 15px;">
                                            <field name="current_stock"/> <field name="uom"/>
                                        </strong>
                                    </div>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- List View (Tree) -->
        <record id="view_material_tree" model="ir.ui.view">
            <field name="name">inventory.monitoring.material.tree</field>
            <field name="model">inventory.monitoring.material</field>
            <field name="arch" type="xml">
                <tree string="Materials" decoration-danger="current_stock &lt; min_stock" decoration-success="current_stock &gt;= min_stock" sample="1">
                    <field name="name"/>
                    <field name="current_stock" decoration-bf="1"/>
                    <field name="min_stock"/>
                    <field name="uom"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_material_form" model="ir.ui.view">
            <field name="name">inventory.monitoring.material.form</field>
            <field name="model">inventory.monitoring.material</field>
            <field name="arch" type="xml">
                <form string="Material">
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1>
                                <field name="name" placeholder="Contoh: Beras"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="uom"/>
                            </group>
                            <group>
                                <field name="current_stock"/>
                                <field name="min_stock"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action window -->
        <record id="action_inventory_material" model="ir.actions.act_window">
            <field name="name">Materials Dashboard</field>
            <field name="res_model">inventory.monitoring.material</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="search_view_id" ref="view_material_search"/>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Belum ada bahan baku tercatat.
              </p>
              <p>
                Tambahkan bahan baku baru untuk memantau stok dapur Anda.
              </p>
            </field>
        </record>
    </data>
</odoo>
