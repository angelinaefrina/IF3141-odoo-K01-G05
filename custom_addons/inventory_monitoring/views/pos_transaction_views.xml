<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pos_transaction_form" model="ir.ui.view">
            <field name="name">inventory.monitoring.pos.transaction.form</field>
            <field name="model">inventory.monitoring.pos.transaction</field>
            <field name="arch" type="xml">
                <form string="POS Transaction">
                    <sheet>
                        <group>
                            <field name="recipe_id"/>
                            <field name="quantity_sold"/>
                            <field name="date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pos_transaction_tree" model="ir.ui.view">
            <field name="name">inventory.monitoring.pos.transaction.tree</field>
            <field name="model">inventory.monitoring.pos.transaction</field>
            <field name="arch" type="xml">
                <tree string="POS Transactions">
                    <field name="date"/>
                    <field name="recipe_id"/>
                    <field name="quantity_sold"/>
                </tree>
            </field>
        </record>

        <record id="action_pos_transaction" model="ir.actions.act_window">
            <field name="name">Simulate POS Transaction</field>
            <field name="res_model">inventory.monitoring.pos.transaction</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>