<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_pos_transaction_form" model="ir.ui.view">
            <field name="name">inventory.monitoring.pos.transaction.form</field>
            <field name="model">inventory.monitoring.pos.transaction</field>
            <field name="arch" type="xml">
                <form string="POS Transaction">
                    <sheet>
                        <group>
                            <field name="recipe_id"/>
                            <field name="quantity_sold"/>
                            <field name="date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_pos_transaction_search" model="ir.ui.view">
            <field name="name">inventory.monitoring.pos.transaction.search</field>
            <field name="model">inventory.monitoring.pos.transaction</field>
            <field name="arch" type="xml">
                <search string="Cari Transaksi POS">
                    <field name="recipe_id" string="Menu Terjual"/>
                    <field name="date" string="Tanggal Transaksi"/>
                    
                    <group expand="0" string="Group By">
                        <filter string="Menu Terjual" name="group_by_recipe" context="{'group_by':'recipe_id'}"/>
                        <filter string="Tanggal" name="group_by_date" context="{'group_by':'date'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="view_pos_transaction_tree" model="ir.ui.view">
            <field name="name">inventory.monitoring.pos.transaction.tree</field>
            <field name="model">inventory.monitoring.pos.transaction</field>
            <field name="arch" type="xml">
                <tree string="POS Transactions">
                    <field name="date"/>
                    <field name="recipe_id"/>
                    <field name="quantity_sold"/>
                </tree>
            </field>
        </record>

        <record id="action_pos_transaction" model="ir.actions.act_window">
            <field name="name">Simulate POS Transaction</field>
            <field name="res_model">inventory.monitoring.pos.transaction</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_pos_transaction_search"/>
        </record>
    </data>
</odoo>