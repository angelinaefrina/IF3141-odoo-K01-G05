<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Search View -->
        <record id="view_report_search" model="ir.ui.view">
            <field name="name">inventory.monitoring.report.search</field>
            <field name="model">inventory.monitoring.report</field>
            <field name="arch" type="xml">
                <search string="Search Reports">
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <group expand="0" string="Group By">
                        <filter string="Date From" name="group_by_date_from" context="{'group_by':'date_from'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- List View (Tree) -->
        <record id="view_report_tree" model="ir.ui.view">
            <field name="name">inventory.monitoring.report.tree</field>
            <field name="model">inventory.monitoring.report</field>
            <field name="arch" type="xml">
                <tree string="Reports" sample="1">
                    <field name="name"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="created_at"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_report_form" model="ir.ui.view">
            <field name="name">inventory.monitoring.report.form</field>
            <field name="model">inventory.monitoring.report</field>
            <field name="arch" type="xml">
                <form string="Inventory Report">
                    <header>
                        <button name="action_export_pdf" string="Export PDF" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                            <group>
                                <field name="created_at" readonly="1"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" widget="text" placeholder="Report content..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action window -->
        <record id="action_inventory_report" model="ir.actions.act_window">
            <field name="name">Inventory Reports</field>
            <field name="res_model">inventory.monitoring.report</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_report_search"/>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Belum ada laporan.
              </p>
              <p>
                Laporan harian akan dibuat otomatis oleh sistem.
              </p>
            </field>
        </record>
    </data>
</odoo>
